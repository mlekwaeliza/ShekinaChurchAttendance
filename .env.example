# Server configuration
PORT=3001
NODE_ENV=development

# Session secret (generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your-secret-key-here

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Database path (optional, defaults to server/database.sqlite)
DB_PATH=./database.sqlite
