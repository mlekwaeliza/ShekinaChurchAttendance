# Server configuration
PORT=3001
NODE_ENV=development

# Session secret (generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your-secret-key-here

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Database driver
# Use sqlite for local quick starts. Use postgres after running the migration/check steps.
DB_CLIENT=sqlite

# SQLite database path (optional, defaults to server/database.sqlite)
DB_PATH=./server/database.sqlite

# PostgreSQL configuration
# Option A: use one URL, recommended for deployment platforms.
# DATABASE_URL=postgres://church_app:change-me@127.0.0.1:5432/church_attendance
#
# Option B: use individual fields.
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=church_attendance
# PGUSER=church_app
# PGPASSWORD=change-me
#
# Set PGSSL=true when your Postgres host requires SSL.
# PGSSL=false
PGPOOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000

# Backup settings
BACKUP_RETENTION_DAYS=30

# Production settings
# Set NODE_ENV=production in production.
# Set CLIENT_URL to the public HTTPS origin, for example https://attendance.example.org
# COOKIE_SECURE=true
# TRUST_PROXY=true

# Operational checklist before production:
# 1. Use a unique 32+ byte SESSION_SECRET and keep it private.
# 2. For SQLite, point DB_PATH to a backed-up persistent volume.
# 3. For PostgreSQL migration, set DATABASE_URL, then run:
#    cd server && npm run postgres:migrate
# 4. Serve the app behind HTTPS and set COOKIE_SECURE=true.
# 5. Set TRUST_PROXY=true when running behind Nginx, Caddy, Apache, or a platform proxy.
